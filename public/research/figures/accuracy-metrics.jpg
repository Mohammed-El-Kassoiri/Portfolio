<svg width="800" height="600" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="600" fill="#0a0a0a"/>
  
  <!-- Title -->
  <text x="400" y="30" font-family="monospace" font-size="20" fill="#06b6d4" text-anchor="middle" font-weight="bold">Model Performance Metrics</text>
  
  <!-- Accuracy Chart -->
  <rect x="50" y="60" width="350" height="250" fill="#1a1a1a" stroke="#06b6d4" stroke-width="2"/>
  <text x="225" y="85" font-family="monospace" font-size="14" fill="#10b981" text-anchor="middle" font-weight="bold">Training & Validation Accuracy</text>
  
  <!-- Axes -->
  <line x1="80" y1="280" x2="370" y2="280" stroke="#ffffff" stroke-width="2"/>
  <line x1="80" y1="110" x2="80" y2="280" stroke="#ffffff" stroke-width="2"/>
  
  <!-- Y-axis labels -->
  <text x="70" y="115" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">1.0</text>
  <text x="70" y="165" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">0.8</text>
  <text x="70" y="215" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">0.6</text>
  <text x="70" y="265" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">0.4</text>
  <text x="70" y="285" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">0.2</text>
  
  <!-- X-axis labels -->
  <text x="80" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">0</text>
  <text x="180" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">50</text>
  <text x="280" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">100</text>
  <text x="370" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">Epoch</text>
  
  <!-- Training curve (green) -->
  <path d="M 80 260 Q 120 240, 160 200 T 240 150 T 320 130 T 370 120" stroke="#10b981" stroke-width="3" fill="none"/>
  
  <!-- Validation curve (cyan) -->
  <path d="M 80 265 Q 120 250, 160 210 T 240 165 T 320 145 T 370 135" stroke="#06b6d4" stroke-width="3" fill="none" stroke-dasharray="5,5"/>
  
  <!-- Legend -->
  <line x1="100" y1="100" x2="130" y2="100" stroke="#10b981" stroke-width="3"/>
  <text x="135" y="105" font-family="monospace" font-size="10" fill="#ffffff">Training</text>
  
  <line x1="200" y1="100" x2="230" y2="100" stroke="#06b6d4" stroke-width="3" stroke-dasharray="5,5"/>
  <text x="235" y="105" font-family="monospace" font-size="10" fill="#ffffff">Validation</text>
  
  <!-- Loss Chart -->
  <rect x="420" y="60" width="350" height="250" fill="#1a1a1a" stroke="#06b6d4" stroke-width="2"/>
  <text x="595" y="85" font-family="monospace" font-size="14" fill="#f59e0b" text-anchor="middle" font-weight="bold">Training Loss Curve</text>
  
  <!-- Axes -->
  <line x1="450" y1="280" x2="740" y2="280" stroke="#ffffff" stroke-width="2"/>
  <line x1="450" y1="110" x2="450" y2="280" stroke="#ffffff" stroke-width="2"/>
  
  <!-- Y-axis labels -->
  <text x="440" y="115" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">2.0</text>
  <text x="440" y="165" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">1.5</text>
  <text x="440" y="215" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">1.0</text>
  <text x="440" y="265" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="end">0.5</text>
  
  <!-- X-axis labels -->
  <text x="450" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">0</text>
  <text x="550" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">50</text>
  <text x="650" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">100</text>
  <text x="740" y="300" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">Epoch</text>
  
  <!-- Loss curve (orange) -->
  <path d="M 450 130 Q 500 160, 550 190 T 650 230 T 740 260" stroke="#f59e0b" stroke-width="3" fill="none"/>
  
  <!-- Confusion Matrix -->
  <rect x="50" y="340" width="350" height="230" fill="#1a1a1a" stroke="#06b6d4" stroke-width="2"/>
  <text x="225" y="365" font-family="monospace" font-size="14" fill="#06b6d4" text-anchor="middle" font-weight="bold">Confusion Matrix</text>
  
  <!-- Matrix grid -->
  <rect x="120" y="400" width="100" height="80" fill="#16a34a" opacity="0.8" stroke="#ffffff" stroke-width="2"/>
  <text x="170" y="445" font-family="monospace" font-size="20" fill="#ffffff" text-anchor="middle" font-weight="bold">4852</text>
  <text x="170" y="465" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">True Positive</text>
  
  <rect x="230" y="400" width="100" height="80" fill="#ef4444" opacity="0.5" stroke="#ffffff" stroke-width="2"/>
  <text x="280" y="445" font-family="monospace" font-size="20" fill="#ffffff" text-anchor="middle" font-weight="bold">168</text>
  <text x="280" y="465" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">False Positive</text>
  
  <rect x="120" y="490" width="100" height="80" fill="#ef4444" opacity="0.5" stroke="#ffffff" stroke-width="2"/>
  <text x="170" y="535" font-family="monospace" font-size="20" fill="#ffffff" text-anchor="middle" font-weight="bold">142</text>
  <text x="170" y="555" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">False Negative</text>
  
  <rect x="230" y="490" width="100" height="80" fill="#16a34a" opacity="0.8" stroke="#ffffff" stroke-width="2"/>
  <text x="280" y="535" font-family="monospace" font-size="20" fill="#ffffff" text-anchor="middle" font-weight="bold">4638</text>
  <text x="280" y="555" font-family="monospace" font-size="10" fill="#ffffff" text-anchor="middle">True Negative</text>
  
  <!-- Labels -->
  <text x="170" y="390" font-family="monospace" font-size="12" fill="#10b981" text-anchor="middle">Predicted: Agriculture</text>
  <text x="280" y="390" font-family="monospace" font-size="12" fill="#10b981" text-anchor="middle">Predicted: Non-Agri</text>
  <text x="90" y="445" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="end">Actual:</text>
  <text x="90" y="460" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="end">Agriculture</text>
  <text x="90" y="535" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="end">Actual:</text>
  <text x="90" y="550" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="end">Non-Agri</text>
  
  <!-- Metrics Summary -->
  <rect x="420" y="340" width="350" height="230" fill="#1a1a1a" stroke="#06b6d4" stroke-width="2"/>
  <text x="595" y="365" font-family="monospace" font-size="14" fill="#06b6d4" text-anchor="middle" font-weight="bold">Performance Summary</text>
  
  <!-- Bar chart for metrics -->
  <text x="450" y="400" font-family="monospace" font-size="12" fill="#ffffff">Accuracy:</text>
  <rect x="550" y="388" width="187" height="18" fill="#10b981" opacity="0.7"/>
  <text x="640" y="400" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">93.6%</text>
  
  <text x="450" y="430" font-family="monospace" font-size="12" fill="#ffffff">Precision:</text>
  <rect x="550" y="418" width="186" height="18" fill="#10b981" opacity="0.7"/>
  <text x="640" y="430" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">92.8%</text>
  
  <text x="450" y="460" font-family="monospace" font-size="12" fill="#ffffff">Recall:</text>
  <rect x="550" y="448" width="188" height="18" fill="#10b981" opacity="0.7"/>
  <text x="640" y="460" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">94.2%</text>
  
  <text x="450" y="490" font-family="monospace" font-size="12" fill="#ffffff">F1-Score:</text>
  <rect x="550" y="478" width="187" height="18" fill="#10b981" opacity="0.7"/>
  <text x="640" y="490" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">93.5%</text>
  
  <text x="450" y="520" font-family="monospace" font-size="12" fill="#ffffff">Mean IoU:</text>
  <rect x="550" y="508" width="162" height="18" fill="#06b6d4" opacity="0.7"/>
  <text x="630" y="520" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">0.81</text>
  
  <text x="450" y="550" font-family="monospace" font-size="12" fill="#ffffff">Kappa:</text>
  <rect x="550" y="538" width="174" height="18" fill="#06b6d4" opacity="0.7"/>
  <text x="635" y="550" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">0.87</text>
</svg>
