<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="450" fill="#0a0a0a"/>
  
  <!-- Grid background -->
  <defs>
    <pattern id="grid2" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#06b6d4" stroke-width="0.5" opacity="0.1"/>
    </pattern>
  </defs>
  <rect width="800" height="450" fill="url(#grid2)"/>
  
  <!-- Title -->
  <text x="400" y="40" font-family="monospace" font-size="20" fill="#06b6d4" text-anchor="middle">Multi-Source Data Integration (16 Bands)</text>
  
  <!-- Sentinel-1 -->
  <rect x="50" y="80" width="160" height="140" fill="#1e40af" opacity="0.5" stroke="#06b6d4" stroke-width="2"/>
  <text x="130" y="110" font-family="monospace" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Sentinel-1</text>
  <text x="130" y="135" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="middle">Radar SAR</text>
  <text x="130" y="155" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">VV Polarization</text>
  <text x="130" y="175" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">VH Polarization</text>
  <text x="130" y="195" font-family="monospace" font-size="10" fill="#10b981" text-anchor="middle">10m Resolution</text>
  
  <!-- Sentinel-2 -->
  <rect x="230" y="80" width="160" height="140" fill="#059669" opacity="0.5" stroke="#06b6d4" stroke-width="2"/>
  <text x="310" y="110" font-family="monospace" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Sentinel-2</text>
  <text x="310" y="135" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="middle">Optical MSI</text>
  <text x="310" y="155" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">10 Spectral Bands</text>
  <text x="310" y="175" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">RGB + NIR + RE</text>
  <text x="310" y="195" font-family="monospace" font-size="10" fill="#10b981" text-anchor="middle">10-20m Resolution</text>
  
  <!-- SMAP -->
  <rect x="410" y="80" width="160" height="140" fill="#7c3aed" opacity="0.5" stroke="#06b6d4" stroke-width="2"/>
  <text x="490" y="110" font-family="monospace" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">SMAP</text>
  <text x="490" y="135" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="middle">Soil Moisture</text>
  <text x="490" y="155" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">Passive Microwave</text>
  <text x="490" y="175" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">Root Zone</text>
  <text x="490" y="195" font-family="monospace" font-size="10" fill="#10b981" text-anchor="middle">9km Resolution</text>
  
  <!-- Topographic -->
  <rect x="590" y="80" width="160" height="140" fill="#ea580c" opacity="0.5" stroke="#06b6d4" stroke-width="2"/>
  <text x="670" y="110" font-family="monospace" font-size="14" fill="#ffffff" text-anchor="middle" font-weight="bold">Topographic</text>
  <text x="670" y="135" font-family="monospace" font-size="11" fill="#ffffff" text-anchor="middle">DEM + Slope</text>
  <text x="670" y="155" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">Elevation Data</text>
  <text x="670" y="175" font-family="monospace" font-size="10" fill="#06b6d4" text-anchor="middle">Terrain Analysis</text>
  <text x="670" y="195" font-family="monospace" font-size="10" fill="#10b981" text-anchor="middle">30m Resolution</text>
  
  <!-- Arrows pointing down -->
  <path d="M 130 230 L 130 280" stroke="#06b6d4" stroke-width="3" marker-end="url(#arrow)"/>
  <path d="M 310 230 L 310 280" stroke="#06b6d4" stroke-width="3" marker-end="url(#arrow)"/>
  <path d="M 490 230 L 490 280" stroke="#06b6d4" stroke-width="3" marker-end="url(#arrow)"/>
  <path d="M 670 230 L 670 280" stroke="#06b6d4" stroke-width="3" marker-end="url(#arrow)"/>
  
  <!-- Arrow marker -->
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="10" refX="5" refY="5" orient="auto">
      <polygon points="0,0 10,5 0,10" fill="#06b6d4"/>
    </marker>
  </defs>
  
  <!-- Fusion box -->
  <rect x="200" y="290" width="400" height="80" fill="#0a0a0a" stroke="#06b6d4" stroke-width="3"/>
  <text x="400" y="320" font-family="monospace" font-size="18" fill="#06b6d4" text-anchor="middle" font-weight="bold">Multi-Modal Data Fusion</text>
  <text x="400" y="345" font-family="monospace" font-size="14" fill="#10b981" text-anchor="middle">16 Spectral + Environmental Bands</text>
  <text x="400" y="365" font-family="monospace" font-size="12" fill="#ffffff" text-anchor="middle">Concatenated Feature Stack</text>
  
  <!-- Bottom arrow -->
  <path d="M 400 380 L 400 400" stroke="#06b6d4" stroke-width="3" marker-end="url(#arrow)"/>
  <text x="400" y="425" font-family="monospace" font-size="14" fill="#06b6d4" text-anchor="middle">→ Attention U-Net Model</text>
</svg>
