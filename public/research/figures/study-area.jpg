<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <rect width="800" height="450" fill="#0a0a0a"/>
  <rect x="10" y="10" width="780" height="430" fill="none" stroke="#06b6d4" stroke-width="2"/>
  
  <!-- Grid pattern -->
  <defs>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#06b6d4" stroke-width="0.5" opacity="0.2"/>
    </pattern>
  </defs>
  <rect width="800" height="450" fill="url(#grid)"/>
  
  <!-- Map outline -->
  <path d="M 150 200 L 200 180 L 280 190 L 350 210 L 400 220 L 450 200 L 500 210 L 550 230 L 600 240 L 620 260 L 600 290 L 550 310 L 500 300 L 450 310 L 400 300 L 350 290 L 300 280 L 250 270 L 200 250 L 150 230 Z" fill="#16a34a" opacity="0.3" stroke="#06b6d4" stroke-width="2"/>
  
  <!-- Location markers -->
  <circle cx="350" cy="250" r="8" fill="#ef4444" stroke="#ffffff" stroke-width="2"/>
  <circle cx="450" cy="270" r="6" fill="#f59e0b" stroke="#ffffff" stroke-width="2"/>
  <circle cx="280" cy="230" r="6" fill="#f59e0b" stroke="#ffffff" stroke-width="2"/>
  
  <!-- Labels -->
  <text x="400" y="100" font-family="monospace" font-size="24" fill="#06b6d4" text-anchor="middle">Study Area: Taroudant, Morocco</text>
  <text x="400" y="130" font-family="monospace" font-size="14" fill="#ffffff" opacity="0.8" text-anchor="middle">Souss-Massa Region - Agricultural Water Stress Monitoring</text>
  
  <!-- Legend -->
  <rect x="50" y="350" width="200" height="80" fill="#0a0a0a" stroke="#06b6d4" stroke-width="1" opacity="0.8"/>
  <rect x="60" y="365" width="15" height="15" fill="#16a34a" opacity="0.5"/>
  <text x="80" y="377" font-family="monospace" font-size="12" fill="#ffffff">Agricultural Area</text>
  <circle cx="67" cy="395" r="5" fill="#ef4444"/>
  <text x="80" y="400" font-family="monospace" font-size="12" fill="#ffffff">Primary Study Site</text>
  <circle cx="67" cy="415" r="4" fill="#f59e0b"/>
  <text x="80" y="420" font-family="monospace" font-size="12" fill="#ffffff">Validation Points</text>
</svg>
